# Web server
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Risk thresholds
HIGH_VALUE_ETH_THRESHOLD=1000000000000000000
HIGH_VALUE_USD_THRESHOLD=1000.0

# EIP-712 validation
EIP712_STRICT_MODE=false

# Performance
ENABLE_CACHING=true
CACHE_SIZE=1000
CACHE_TTL=3600

# LLM (optional)
LLM_ENABLED=false
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=100
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false
LOG_FILE_PATH=logs/signature_decoder.log

# External APIs
ETHERSCAN_API_KEY=
