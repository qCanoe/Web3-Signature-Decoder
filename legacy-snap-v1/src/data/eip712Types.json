{
  "comment": "常见 EIP-712 类型定义",
  "types": {
    "Permit": {
      "description": "ERC20 Permit (EIP-2612)",
      "fields": ["owner", "spender", "value", "nonce", "deadline"],
      "riskFactors": {
        "unlimitedValue": {
          "field": "value",
          "check": "isMaxUint256",
          "message": "无限授权"
        },
        "longDeadline": {
          "field": "deadline",
          "check": "isLongDeadline",
          "message": "授权期限较长"
        }
      }
    },
    "PermitSingle": {
      "description": "Permit2 单一授权",
      "protocol": "Permit2",
      "fields": ["details", "spender", "sigDeadline"],
      "riskFactors": {
        "unlimitedAmount": {
          "field": "details.amount",
          "check": "isMaxUint256",
          "message": "无限授权金额"
        },
        "longExpiration": {
          "field": "details.expiration",
          "check": "isLongExpiration",
          "message": "授权期限较长"
        }
      }
    },
    "PermitBatch": {
      "description": "Permit2 批量授权",
      "protocol": "Permit2",
      "fields": ["details", "spender", "sigDeadline"],
      "riskFactors": {
        "multipleTokens": {
          "field": "details",
          "check": "isArray",
          "message": "批量授权多个代币"
        }
      }
    },
    "PermitWitnessTransferFrom": {
      "description": "Permit2 带见证的转账",
      "protocol": "Permit2",
      "fields": ["permitted", "spender", "nonce", "deadline", "witness"]
    },
    "OrderComponents": {
      "description": "Seaport 订单",
      "protocol": "OpenSea Seaport",
      "fields": ["offerer", "zone", "offer", "consideration", "orderType"]
    },
    "Order": {
      "description": "通用订单类型",
      "possibleProtocols": ["CoW Protocol", "1inch", "Other DEX"],
      "fields": ["maker", "taker", "makerAmount", "takerAmount"]
    },
    "SafeTx": {
      "description": "Safe 多签交易",
      "protocol": "Gnosis Safe",
      "fields": ["to", "value", "data", "operation", "safeTxGas", "nonce"]
    },
    "Delegation": {
      "description": "投票/治理委托",
      "fields": ["delegatee", "nonce", "expiry"]
    },
    "ForwardRequest": {
      "description": "元交易转发请求",
      "fields": ["from", "to", "value", "gas", "nonce", "data"],
      "riskFactors": {
        "gaslessTransaction": {
          "message": "此为代付 Gas 的元交易"
        }
      }
    }
  },
  "protocolDomains": {
    "Permit2": {
      "names": ["Permit2"],
      "verifyingContracts": [
        "0x000000000022d473030f116ddee9f6b43ac78ba3"
      ]
    },
    "Seaport": {
      "names": ["Seaport"],
      "verifyingContracts": [
        "0x00000000000000adc04c56bf30ac9d3c0aaf14dc",
        "0x00000000006c3852cbef3e08e8df289169ede581"
      ]
    },
    "UniswapPermit2": {
      "names": ["Uniswap", "Permit2"],
      "verifyingContracts": [
        "0x000000000022d473030f116ddee9f6b43ac78ba3"
      ]
    }
  }
}
