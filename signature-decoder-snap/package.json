{
  "name": "@signature-decoder/snap",
  "version": "0.1.0",
  "description": "A MetaMask Snap that provides signature and transaction insights with semantic analysis",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/signature-decoder-snap.git"
  },
  "license": "MIT",
  "main": "./dist/bundle.js",
  "files": [
    "dist/",
    "snap.manifest.json"
  ],
  "scripts": {
    "build": "mm-snap build",
    "build:clean": "yarn clean && yarn build",
    "clean": "rimraf dist",
    "lint": "yarn lint:eslint && yarn lint:misc --check",
    "lint:eslint": "eslint . --cache --ext js,jsx,ts,tsx",
    "lint:fix": "yarn lint:eslint --fix && yarn lint:misc --write",
    "lint:misc": "prettier '**/*.json' '**/*.md' '!dist/**' --ignore-path .gitignore",
    "serve": "mm-snap serve",
    "start": "mm-snap watch",
    "test": "jest"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "^6.22.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@lavamoat/allow-scripts": "^3.3.1",
    "@metamask/auto-changelog": "^3.4.4",
    "@metamask/eslint-config": "^13.0.0",
    "@metamask/eslint-config-jest": "^13.0.0",
    "@metamask/eslint-config-nodejs": "^13.0.0",
    "@metamask/eslint-config-typescript": "^13.0.0",
    "@metamask/snaps-cli": "^6.5.1",
    "@metamask/snaps-jest": "^8.8.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-x": "^4.5.0",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-jsdoc": "^50.5.0",
    "eslint-plugin-n": "^17.14.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
